generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Auth.js Models (required by @auth/prisma-adapter)
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified      DateTime?
  image              String?
  githubId           String?   @unique
  notifyEmail        String?
  isPublicBadgeEnabled Boolean @default(false)
  notificationSentAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  githubInstallation GitHubInstallation?
  leetcodeCredential LeetCodeCredential?
  syncedSubmissions  SyncedSubmission[]
  syncLogs           SyncLog[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ============================================================
// LeetPush Domain Models
// ============================================================

model GitHubInstallation {
  id                    String   @id @default(cuid())
  userId                String   @unique
  installationId        Int
  repoOwner             String
  repoName              String
  repoFullName          String   // "owner/repo"
  folderPattern         String   @default("{questionId}-{titleSlug}/{titleSlug}.{ext}")
  commitMessageTemplate String   @default("Add: {questionId}. {title} ({lang})")
  defaultBranch         String   @default("main")
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum CredentialStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

model LeetCodeCredential {
  id                 String           @id @default(cuid())
  userId             String           @unique
  encryptedSession   String           @db.Text
  encryptedCsrfToken String           @db.Text
  leetcodeUsername    String?
  status             CredentialStatus @default(ACTIVE)
  lastVerifiedAt     DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SyncedSubmission {
  id                    String   @id @default(cuid())
  userId                String
  leetcodeSubmissionId  String   @unique // LeetCode's own submission ID — the dedup key
  problemSlug           String
  problemTitle          String
  questionId            String
  language              String
  difficulty            String?
  tags                  String[]
  runtime               String?
  memory                String?
  runtimePercentile     Float?
  memoryPercentile      Float?
  commitSha             String?
  commitUrl             String?
  readmePath            String?
  syncedAt              DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, syncedAt(sort: Desc)])
  @@index([userId, leetcodeSubmissionId])
}

enum SyncStatus {
  SUCCESS
  PARTIAL
  FAILURE
  NO_NEW
}

model SyncLog {
  id                  String     @id @default(cuid())
  userId              String
  runAt               DateTime   @default(now())
  status              SyncStatus
  newSubmissionsCount Int        @default(0)
  errorMessage        String?    @db.Text
  durationMs          Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, runAt(sort: Desc)])
}
