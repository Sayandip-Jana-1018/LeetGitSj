# ============================================================
# LeetGitSj Environment Variables
# Copy this to .env.local and fill in real values
# NEVER commit .env.local to version control
# ============================================================

# --- Auth.js ---
AUTH_SECRET=          # Generate with: npx auth secret
AUTH_URL=http://localhost:3000

# --- GitHub OAuth App (for user login ONLY) ---
GITHUB_CLIENT_ID=     # From github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_SECRET= # Generated once on creation — copy immediately

# --- GitHub App (for repo write access) ---
GITHUB_APP_ID=                # Numeric App ID from App settings page
GITHUB_APP_PRIVATE_KEY=       # Full RSA private key (.pem contents, with \n for newlines)
GITHUB_APP_WEBHOOK_SECRET=    # The secret you set when creating the App's webhook
GITHUB_APP_CLIENT_ID=         # The App's Client ID (Iv23li...)
GITHUB_APP_SLUG=              # The slug from your App's public URL (e.g. "leetgit-sayandip")

# --- Database (PostgreSQL via Neon) ---
DATABASE_URL=         # Pooled connection string from Neon dashboard

# --- Redis (Upstash — use TCP/TLS connection, NOT REST) ---
REDIS_URL=            # rediss://default:PASSWORD@ENDPOINT:PORT

# --- Encryption ---
ENCRYPTION_KEY=       # 32-byte hex string. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# --- Sentry (optional but recommended) ---
SENTRY_DSN=           # From sentry.io project settings
NEXT_PUBLIC_SENTRY_DSN=  # Same DSN, exposed to client for frontend error tracking

# --- AI README Generation (optional — falls back to metadata-only README) ---
GEMINI_API_KEY=       # From aistudio.google.com → API Keys

# --- Email Notifications (optional — skips if not set) ---
RESEND_API_KEY=       # From resend.com → API Keys
RESEND_FROM_EMAIL=    # e.g. "LeetGitSj <notifications@yourdomain.com>"

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GITHUB_APP_SLUG=leetgit-sayandip
